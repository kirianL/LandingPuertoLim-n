---
const { pathname } = Astro.url;

// Normalize path to remove trailing slash
const currentPath = pathname.replace(/\/$/, "");

const navigation = [
  {
    name: "Inicio",
    href: "",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-home"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`
  },
  {
    name: "Historia y Patrimonio",
    href: "/historia-patrimonio",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-book-open"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`
  },
  {
    name: "Cultura",
    href: "/cultura",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-music"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`
  },
  {
    name: "Naturaleza",
    href: "/naturaleza",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trees"><path d="M10 10v.01"/><path d="M16 10v.01"/><path d="M14 19H2a2 2 0 0 1-2-2v-1a2 2 0 0 1 2-2h4M12 19h10a2 2 0 0 0 2-2v-1a2 2 0 0 0-2-2h-4"/><path d="M12 2v8M12 2C9.5 2 7 4 7 7c0 2.5 2 3 5 3M12 2c2.5 0 5 2 5 5 0 2.5-2 3-5 3"/><path d="M8 14v5M16 14v5"/></svg>`
  },
  {
    name: "Gastronomía",
    href: "/gastronomia",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-utensils"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v8c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>`
  },
  {
    name: "Deportes y Eventos",
    href: "/deportes-eventos",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar-days"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>`
  },
  {
    name: "Mi Ruta",
    href: "/ruta",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map"><path d="M14.14 22l.52-1.9a1 1 0 0 0-.66-1.19L4 15.35M16 12l4 1.35V20l-4-1.35Zm-4 1.35V22l-4-1.35V14.8M4 6.7l8-2.7 8 2.7v7.5l-8-2.7-8 2.7Z"/></svg>`
  },
];
---

<!-- Invisible/Integrated Header Bar -->
<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 w-full transition-all duration-300 ease-in-out py-6 border-b border-transparent bg-transparent"
>
  <div class="max-w-[1600px] mx-auto px-4 sm:px-12 lg:px-16">
    <div class="flex items-center justify-between h-12">
      <!-- Brand Logo/Link -->
      <a href="/" class="flex items-center gap-2 group relative z-50">
        <span class="font-display font-bold text-xl md:text-2xl text-white group-hover:text-limon-amarillo-400 transition-colors duration-300 uppercase tracking-tight" id="header-brand">
          Puerto Limón
        </span>
      </a>

      <!-- Desktop Navigation Menu (Invisible/Integrated) -->
      <nav class="hidden lg:block relative z-50">
        <ul class="flex items-center gap-2">
          {navigation.map((item) => {
            const isActive = (item.href === "" && currentPath === "") || (item.href !== "" && currentPath === item.href);
            
            return (
              <li>
                <a
                  href={item.href || "/"}
                  data-astro-prefetch
                  class={`relative px-4 py-2 text-xs font-bold uppercase tracking-wider transition-colors duration-200 block ${
                    isActive
                      ? "text-limon-amarillo-400 font-extrabold"
                      : "text-white/80 hover:text-white"
                  }`}
                  id="nav-link"
                >
                  {item.name}
                  {isActive && (
                    <span class="absolute bottom-0 left-4 right-4 h-0.5 bg-limon-amarillo-400 rounded-full" />
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <!-- Utilities (Theme Toggle & Mobile Menu) -->
      <div class="flex items-center gap-4 relative z-50">
        <!-- Mobile Menu Toggle Button (Inverted color for dark backdrop) -->
        <button
          id="mobile-menu-toggle"
          class="lg:hidden flex flex-col justify-center items-center w-10 h-10 rounded-xl hover:bg-white/10 text-white focus:outline-none transition-colors"
          aria-label="Abrir menú de navegación"
        >
          <div class="w-5 h-0.5 bg-current rounded transition-all duration-300 menu-line-1"></div>
          <div class="w-5 h-0.5 bg-current rounded my-1.5 transition-all duration-300 menu-line-2"></div>
          <div class="w-5 h-0.5 bg-current rounded transition-all duration-300 menu-line-3"></div>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Notion-Style Mobile Navigation Drawer (Light Mode, Minimalist, Dropdown from Top) -->
<div id="mobile-drawer-backdrop" class="fixed inset-0 bg-black/25 backdrop-blur-sm z-40 hidden transition-opacity duration-300 opacity-0"></div>
<nav
  id="mobile-drawer"
  class="fixed top-0 left-0 right-0 w-full bg-[#ffffff] border-b border-zinc-200/80 shadow-lg z-50 overflow-y-auto transform -translate-y-full transition-transform duration-300 ease-out hidden pb-8"
>
  <div class="p-5 flex flex-col h-full justify-between">
    <div class="space-y-6">
      <!-- Notion Drawer Header -->
      <div class="flex items-center justify-between pb-3 border-b border-zinc-200/60">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-limon-selva-600"></div>
          <span class="text-sm font-bold tracking-tight text-zinc-800 uppercase font-grotesk">
            Puerto Limón
          </span>
        </div>
        <button
          id="mobile-menu-close"
          class="p-1.5 rounded hover:bg-zinc-200/60 text-zinc-400 hover:text-zinc-600 transition-colors focus:outline-none"
          aria-label="Cerrar menú"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Notion Sidebar List Style -->
      <div>
        <span class="text-[10px] font-bold uppercase tracking-wider text-zinc-400 block px-3 mb-2">Navegación</span>
        <ul class="space-y-0.5">
          {navigation.map((item) => {
            const isActive = (item.href === "" && currentPath === "") || (item.href !== "" && currentPath === item.href);
            
            return (
              <li>
                <a
                  href={item.href || "/"}
                  data-astro-prefetch
                  class={`flex items-center gap-3 px-3 py-2 rounded-md text-sm transition-all duration-150 ${
                    isActive
                      ? "bg-zinc-200/50 text-limon-selva-700 font-semibold"
                      : "text-zinc-600 hover:text-zinc-900 hover:bg-zinc-100"
                  }`}
                >
                  <span class={`flex-shrink-0 transition-colors ${isActive ? "text-limon-selva-600" : "text-zinc-400 group-hover:text-zinc-600"}`} Fragment set:html={item.icon}></span>
                  <span>{item.name}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </div>

    <!-- Notion Style Sidebar Footer -->
    <div class="pt-6 border-t border-zinc-200/60 text-center">
      <p class="text-xs text-zinc-400 italic leading-relaxed">
        "Lo mejor de Limón es su gente"
      </p>
    </div>
  </div>
</nav>

<script>
  function setupHeader() {
    const header = document.getElementById('main-header');
    const brand = document.getElementById('header-brand');
    const navLinks = document.querySelectorAll('#nav-link');
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const closeBtn = document.getElementById('mobile-menu-close');
    const backdrop = document.getElementById('mobile-drawer-backdrop');
    const drawer = document.getElementById('mobile-drawer');

    if (!header || !brand || !navLinks.length) return;

    // Detect if current page is not home
    const isNotHome = window.location.pathname.replace(/\/$/, "") !== "";

    function handleScroll() {
      if (window.scrollY > 50 || isNotHome) {
        // Scrolled state / Inner pages state: add subtle background blur, dark text since we are in Light Mode
        header?.classList.remove('bg-transparent', 'py-6');
        header?.classList.add('bg-white/95', 'backdrop-blur-md', 'border-zinc-200/80', 'py-4', 'shadow-sm');
        
        brand?.classList.remove('text-white');
        brand?.classList.add('text-zinc-800');
        
        navLinks.forEach(link => {
          if (!link.classList.contains('text-limon-amarillo-400')) {
            link.classList.remove('text-white/80', 'hover:text-white');
            link.classList.add('text-zinc-600', 'hover:text-zinc-900');
          }
        });
        
        toggleBtn?.classList.remove('text-white');
        toggleBtn?.classList.add('text-zinc-800');
      } else {
        // Top state (on home page): completely transparent, white text for contrast on hero image
        header?.classList.add('bg-transparent', 'py-6');
        header?.classList.remove('bg-white/95', 'backdrop-blur-md', 'border-zinc-200/80', 'py-4', 'shadow-sm');
        
        brand?.classList.remove('text-zinc-800');
        brand?.classList.add('text-white');
        
        navLinks.forEach(link => {
          if (!link.classList.contains('text-limon-amarillo-400')) {
            link.classList.remove('text-zinc-600', 'hover:text-zinc-900');
            link.classList.add('text-white/80', 'hover:text-white');
          }
        });
        
        toggleBtn?.classList.remove('text-zinc-800');
        toggleBtn?.classList.add('text-white');
      }
    }

    // Run on scroll
    window.addEventListener('scroll', handleScroll);
    handleScroll();

    // Mobile drawer toggle logic
    if (toggleBtn && closeBtn && backdrop && drawer) {
      function openMenu() {
        drawer?.classList.remove('hidden');
        backdrop?.classList.remove('hidden');
        setTimeout(() => {
          drawer?.classList.remove('-translate-y-full');
          backdrop?.classList.remove('opacity-0');
        }, 10);
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        drawer?.classList.add('-translate-y-full');
        backdrop?.classList.add('opacity-0');
        setTimeout(() => {
          drawer?.classList.add('hidden');
          backdrop?.classList.add('hidden');
        }, 300);
        document.body.style.overflow = '';
      }

      toggleBtn.addEventListener('click', openMenu);
      closeBtn.addEventListener('click', closeMenu);
      backdrop.addEventListener('click', closeMenu);

      // Close mobile drawer immediately when a link is clicked to give instant feedback
      const drawerLinks = drawer.querySelectorAll('a');
      drawerLinks.forEach(link => {
        link.addEventListener('click', closeMenu);
      });
    }
  }

  // Initial setup and lifecycle transitions
  setupHeader();
  document.addEventListener('astro:after-swap', setupHeader);
</script>
